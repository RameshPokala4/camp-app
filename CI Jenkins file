pipeline {
    agent any
    tools {
        nodejs 'NodeJS'
    }
    environment {
        SCANNER_HOME = tool 'mysonar'
    }

    stages {
        
        stage('Clean WS') {
            steps {
                cleanWs()
            }
        }

        stage('Code') {
            steps {
                git 'https://github.com/RameshPokala4/devsecops-project.git'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    sh """
                    ${SCANNER_HOME}/bin/sonar-scanner \
                      -Dsonar.projectKey=CampApp \
                      -Dsonar.projectName=CampApp \
                      -Dsonar.sources=.
                    """
                }
            }
        }
        stage('SonarQube Quality Gate') {
                steps {
                    timeout(time: 3, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                    }
                }
            }
        stage ('Install Dependencies'){
            steps{
                 sh 'npm install'
            }
        }
        stage ('Test app'){
            steps{
                 sh 'npm test'
            }
        }
       stage('OWASP-DC') {
            steps {
               dependencyCheck( additionalArguments: '''
                --scan .
                --format XML
                --out .
                --disableYarnAudit
                --disableNodeAudit''',odcInstallation: 'OWASP-DC')
            }
        }

        stage('Publish OWASP Report') {
            steps {
                dependencyCheckPublisher(pattern: '**/*.xml')
            }
        }
        stage ('Build Docker Image'){
            steps{
                sh 'docker build -t rameshpokala/camp_app:latest .'
            }
        }
        stage ('Trivy image scan'){
            steps{
                sh 'trivy image rameshpokala/camp_app:latest'
            }
        }
        stage ('Docker push'){
            steps{
               script {
                    withDockerRegistry(credentialsId: 'docker-hub') {
                    sh 'docker push rameshpokala/camp_app:latest'
                  }
               }
            }
        }
    }
}
